{
  "name": "Guille_AI_Dev_Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "settings": {
    "python.defaultInterpreterPath": "/usr/local/bin/python"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "extensions": [
    "ms-python.python",
    "ms-toolsai.jupyter"
  ],
  "remoteUser": "root"
}